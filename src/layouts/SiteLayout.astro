---
import type { LanguageDefinition } from "../lib/i18n"

type Props = {
  language?: LanguageDefinition
  title: string
  description: string
}

const { language, title, description } = Astro.props
---

<!doctype html>
<html lang={language?.htmlLang ?? "es"}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <style>
      * {
        box-sizing: border-box;
      }

      html,
      body {
        margin: 0;
        min-height: 100%;
        height: 100%;
      }

      html.scalar-language-transition-lock {
        overflow: hidden;
      }

      body {
        font-family: "IBM Plex Sans", "Segoe UI", sans-serif;
        background: white;
        overflow: hidden;
      }

      body.scalar-language-transition-lock {
        position: fixed;
        inset: 0;
        width: 100%;
        overflow: hidden;
      }

      a {
        color: inherit;
      }
    </style>
  </head>
  <body><slot /></body>
</html>
